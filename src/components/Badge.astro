---
/**
 * DaisyUI Badge Component
 * A compact label for status, categories, or metadata
 */
interface Props {
  variant?: 'default' | 'primary' | 'secondary' | 'accent' | 'ghost' | 'info' | 'success' | 'warning' | 'error';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  outline?: boolean;
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  outline = false,
  class: className = '',
} = Astro.props;

const variantClasses: Record<string, string> = {
  default: '',
  primary: 'badge-primary',
  secondary: 'badge-secondary',
  accent: 'badge-accent',
  ghost: 'badge-ghost',
  info: 'badge-info',
  success: 'badge-success',
  warning: 'badge-warning',
  error: 'badge-error',
};

const sizeClasses: Record<string, string> = {
  xs: 'badge-xs',
  sm: 'badge-sm',
  md: '',
  lg: 'badge-lg',
};

const badgeClasses = [
  'badge',
  variantClasses[variant],
  sizeClasses[size],
  outline && 'badge-outline',
  className,
].filter(Boolean).join(' ');
---

<span class={badgeClasses}>
  <slot />
</span>

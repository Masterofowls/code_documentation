---
/**
 * Bookmark.astro — localStorage-based bookmark button.
 * Adds or removes the current page from saved bookmarks.
 * Works fully offline (no backend required).
 *
 * Usage: <Bookmark title="Page Title" url="/path/to/page" />
 */
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const id = `bm-${url.replace(/\//g, '-')}`;
---

<button
  class="bookmark-btn"
  id={id}
  data-title={title}
  data-url={url}
  aria-label={`Bookmark: ${title}`}
  title="Bookmark this page"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
  </svg>
  <span class="bookmark-label">Bookmark</span>
</button>

<script>
  function initBookmarks() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.bookmark-btn');

    buttons.forEach((btn) => {
      const url = btn.dataset['url'] ?? '';
      const title = btn.dataset['title'] ?? '';
      const stored = JSON.parse(localStorage.getItem('bookmarks') ?? '[]') as Array<{url: string; title: string}>;
      const isBookmarked = stored.some((b) => b.url === url);

      updateButton(btn, isBookmarked);

      btn.addEventListener('click', () => {
        const current = JSON.parse(localStorage.getItem('bookmarks') ?? '[]') as Array<{url: string; title: string}>;
        const idx = current.findIndex((b) => b.url === url);

        if (idx === -1) {
          current.push({ url, title });
          updateButton(btn, true);
        } else {
          current.splice(idx, 1);
          updateButton(btn, false);
        }

        localStorage.setItem('bookmarks', JSON.stringify(current));
      });
    });
  }

  function updateButton(btn: HTMLButtonElement, bookmarked: boolean) {
    const label = btn.querySelector('.bookmark-label');
    if (label) {
      label.textContent = bookmarked ? 'Bookmarked' : 'Bookmark';
    }
    btn.classList.toggle('bookmarked', bookmarked);
    btn.setAttribute('aria-pressed', String(bookmarked));
  }

  // Run on load and after Astro view transitions
  document.addEventListener('DOMContentLoaded', initBookmarks);
  document.addEventListener('astro:page-load', initBookmarks);
</script>

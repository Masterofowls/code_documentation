---
/**
 * BookmarkList.astro — Displays all saved bookmarks from localStorage.
 * Renders a list of bookmarked pages with links and remove buttons.
 * Works fully offline.
 *
 * Usage: <BookmarkList />
 */
---

<div class="bookmark-list" id="bookmark-list">
  <p class="bookmark-empty" id="bookmark-empty" style="display:none">
    No bookmarks saved yet. Click <strong>Bookmark</strong> on any page to save it here.
  </p>
  <ul class="bookmark-items" id="bookmark-items" aria-label="Saved bookmarks"></ul>
</div>

<style>
  .bookmark-list {
    margin-top: 1rem;
  }

  .bookmark-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bookmark-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--sl-color-gray-2);
    border-radius: 8px;
    transition: border-color 0.15s;
  }

  [data-theme='dark'] .bookmark-item {
    border-color: var(--sl-color-gray-5);
  }

  .bookmark-item:hover {
    border-color: var(--sl-color-accent);
  }

  .bookmark-link {
    text-decoration: none;
    color: var(--sl-color-text);
    font-size: 0.9rem;
    font-weight: 500;
    flex: 1;
  }

  .bookmark-link:hover {
    color: var(--sl-color-accent);
  }

  .bookmark-remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sl-color-gray-3);
    padding: 0.2rem;
    border-radius: 4px;
    line-height: 1;
    font-size: 1rem;
    transition: color 0.15s;
  }

  .bookmark-remove:hover {
    color: #ef4444;
  }

  .bookmark-empty {
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }
</style>

<script>
  interface Bookmark {
    url: string;
    title: string;
  }

  function renderBookmarks() {
    const list = document.getElementById('bookmark-items');
    const empty = document.getElementById('bookmark-empty');
    if (!list || !empty) return;

    const bookmarks: Bookmark[] = JSON.parse(
      localStorage.getItem('bookmarks') ?? '[]',
    );

    list.innerHTML = '';

    if (bookmarks.length === 0) {
      empty.style.display = 'block';
      return;
    }

    empty.style.display = 'none';

    bookmarks.forEach(({ url, title }) => {
      const li = document.createElement('li');
      li.className = 'bookmark-item';

      const a = document.createElement('a');
      a.href = url;
      a.className = 'bookmark-link';
      a.textContent = title;

      const removeBtn = document.createElement('button');
      removeBtn.className = 'bookmark-remove';
      removeBtn.textContent = '×';
      removeBtn.setAttribute('aria-label', `Remove bookmark: ${title}`);
      removeBtn.addEventListener('click', () => {
        const current: Bookmark[] = JSON.parse(
          localStorage.getItem('bookmarks') ?? '[]',
        );
        const updated = current.filter((b) => b.url !== url);
        localStorage.setItem('bookmarks', JSON.stringify(updated));
        renderBookmarks();
      });

      li.appendChild(a);
      li.appendChild(removeBtn);
      list.appendChild(li);
    });
  }

  document.addEventListener('DOMContentLoaded', renderBookmarks);
  document.addEventListener('astro:page-load', renderBookmarks);
</script>

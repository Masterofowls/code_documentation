---
/**
 * DaisyUI Card Component
 * A flexible card component for displaying content with various styles
 */
interface Props {
  title?: string;
  description?: string;
  image?: {
    src: string;
    alt: string;
  };
  badges?: string[];
  variant?: 'default' | 'primary' | 'secondary' | 'accent' | 'bordered' | 'glass';
  compact?: boolean;
  href?: string;
  class?: string;
}

const {
  title,
  description,
  image,
  badges = [],
  variant = 'default',
  compact = false,
  href,
  class: className = '',
} = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-base-100',
  primary: 'bg-primary text-primary-content',
  secondary: 'bg-secondary text-secondary-content',
  accent: 'bg-accent text-accent-content',
  bordered: 'card-bordered bg-base-100',
  glass: 'glass',
};

const cardClasses = [
  'card',
  'shadow-xl',
  compact && 'card-compact',
  variantClasses[variant],
  className,
].filter(Boolean).join(' ');

const CardWrapper = href ? 'a' : 'div';
---

<CardWrapper class={cardClasses} href={href}>
  {image && (
    <figure>
      <img src={image.src} alt={image.alt} loading="lazy" />
    </figure>
  )}
  <div class="card-body">
    {title && (
      <h2 class="card-title">
        {title}
        {badges.map((badge) => (
          <span class="badge badge-secondary">{badge}</span>
        ))}
      </h2>
    )}
    {description && <p>{description}</p>}
    <slot />
    <slot name="actions">
      <!-- Default actions slot -->
    </slot>
  </div>
</CardWrapper>

<style>
  .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  }

  a.card {
    cursor: pointer;
    text-decoration: none;
  }
</style>

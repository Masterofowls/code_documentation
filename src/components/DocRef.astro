---
/**
 * DocRef.astro — External documentation reference card.
 * Renders a styled link card pointing to official docs (MDN, etc.)
 *
 * Usage:
 * <DocRef
 *   title="MDN: Array.prototype.map()"
 *   href="https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Array/map"
 *   description="Official MDN documentation for Array.map"
 *   source="MDN Web Docs"
 *   icon="📖"
 * />
 */
interface Props {
  title: string;
  href: string;
  description?: string;
  source?: string;
  icon?: string;
}

const {
  title,
  href,
  description,
  source = 'External Reference',
  icon = '🔗',
} = Astro.props;
---

<a
  class="doc-ref"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${source}: ${title}`}
>
  <span class="doc-ref-icon" aria-hidden="true">{icon}</span>
  <div>
    <div class="doc-ref-title">{title}</div>
    {description && <div class="doc-ref-desc">{description}</div>}
    <div class="doc-ref-source">{source} ↗</div>
  </div>
</a>

<style>
  .doc-ref-source {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.15rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>

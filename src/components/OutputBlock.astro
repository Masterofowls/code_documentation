---
/**
 * OutputBlock.astro — Styled terminal/code output display.
 * Shows the expected output of a code example in a visually distinct block.
 *
 * Usage:
 * <OutputBlock>
 * Hello, World!
 * 42
 * </OutputBlock>
 *
 * Or with a custom label:
 * <OutputBlock label="Result">
 * {'name': 'Alice', 'age': 30}
 * </OutputBlock>
 */
interface Props {
  label?: string;
}

const { label = 'Output' } = Astro.props;
---

<div class="output-block" role="region" aria-label={label}>
  <span class="output-label">{label}</span>
  <slot />
</div>

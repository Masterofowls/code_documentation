---
/**
 * Preload Component
 * Adds resource hints for critical assets to improve loading performance
 */

interface Props {
  /** Fonts to preload */
  fonts?: string[];
  /** Critical CSS files to preload */
  styles?: string[];
  /** Critical JS modules to preload */
  scripts?: string[];
  /** Origins to preconnect to */
  preconnect?: string[];
  /** Origins to prefetch DNS for */
  dnsPrefetch?: string[];
}

const {
  fonts = [],
  styles = [],
  scripts = [],
  preconnect = [
    'https://fonts.googleapis.com',
    'https://fonts.gstatic.com',
  ],
  dnsPrefetch = [
    'https://www.google-analytics.com',
    'https://giscus.app',
  ],
} = Astro.props;
---

{/* Preconnect to critical origins */}
{preconnect.map((origin) => (
  <link rel="preconnect" href={origin} crossorigin="anonymous" />
))}

{/* DNS prefetch for non-critical origins */}
{dnsPrefetch.map((origin) => (
  <link rel="dns-prefetch" href={origin} />
))}

{/* Preload fonts */}
{fonts.map((font) => (
  <link
    rel="preload"
    href={font}
    as="font"
    type={font.endsWith('.woff2') ? 'font/woff2' : 'font/woff'}
    crossorigin="anonymous"
  />
))}

{/* Preload critical styles */}
{styles.map((style) => (
  <link rel="preload" href={style} as="style" />
))}

{/* Module preload for critical scripts */}
{scripts.map((script) => (
  <link rel="modulepreload" href={script} />
))}

{/* Fetchpriority hints for document */}
<meta http-equiv="x-dns-prefetch-control" content="on" />

{/* Preload critical assets inline */}
<script is:inline>
  // Early hints for browsers that support Priority Hints
  (function() {
    // Mark LCP candidate images as high priority
    document.addEventListener('DOMContentLoaded', function() {
      var firstImage = document.querySelector('article img, main img');
      if (firstImage) {
        firstImage.setAttribute('fetchpriority', 'high');
        firstImage.setAttribute('loading', 'eager');
      }

      // Mark below-the-fold images as low priority
      var images = document.querySelectorAll('img[loading="lazy"]');
      images.forEach(function(img) {
        img.setAttribute('fetchpriority', 'low');
      });
    });

    // Prefetch visible links on idle
    if ('requestIdleCallback' in window) {
      requestIdleCallback(function() {
        var links = document.querySelectorAll('a[href^="/"]');
        var prefetched = new Set();

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var href = entry.target.href;
              if (!prefetched.has(href)) {
                var link = document.createElement('link');
                link.rel = 'prefetch';
                link.href = href;
                link.as = 'document';
                document.head.appendChild(link);
                prefetched.add(href);
                observer.unobserve(entry.target);
              }
            }
          });
        }, { rootMargin: '50px' });

        links.forEach(function(link) {
          observer.observe(link);
        });
      }, { timeout: 2000 });
    }
  })();
</script>

---
/**
 * DaisyUI Tabs Component
 * A tab interface for organizing code examples or content
 */
interface Tab {
  id: string;
  label: string;
  icon?: string;
}

interface Props {
  tabs: Tab[];
  defaultTab?: string;
  variant?: 'bordered' | 'lifted' | 'boxed';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  tabs,
  defaultTab = tabs[0]?.id,
  variant = 'bordered',
  size = 'md',
  class: className = '',
} = Astro.props;

const tabsId = `tabs-${Math.random().toString(36).substring(2, 9)}`;

const variantClasses: Record<string, string> = {
  bordered: 'tabs-bordered',
  lifted: 'tabs-lifted',
  boxed: 'tabs-boxed',
};

const sizeClasses: Record<string, string> = {
  xs: 'tabs-xs',
  sm: 'tabs-sm',
  md: '',
  lg: 'tabs-lg',
};

const tabClasses = [
  'tabs',
  variantClasses[variant],
  sizeClasses[size],
  className,
].filter(Boolean).join(' ');
---

<div class="tabs-container" data-tabs-id={tabsId}>
  <div role="tablist" class={tabClasses}>
    {tabs.map((tab) => (
      <button
        role="tab"
        class:list={['tab', { 'tab-active': tab.id === defaultTab }]}
        data-tab={tab.id}
        aria-selected={tab.id === defaultTab}
        aria-controls={`${tabsId}-${tab.id}`}
      >
        {tab.icon && <span class="mr-1" set:html={tab.icon} />}
        {tab.label}
      </button>
    ))}
  </div>
  <div class="tab-panels">
    {tabs.map((tab) => (
      <div
        role="tabpanel"
        id={`${tabsId}-${tab.id}`}
        class:list={['tab-panel', { hidden: tab.id !== defaultTab }]}
        data-panel={tab.id}
      >
        <slot name={tab.id} />
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('.tabs-container').forEach((container) => {
    const tabs = container.querySelectorAll('[role="tab"]');
    const panels = container.querySelectorAll('[role="tabpanel"]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab');

        // Update tab states
        tabs.forEach((t) => {
          t.classList.remove('tab-active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('tab-active');
        tab.setAttribute('aria-selected', 'true');

        // Update panel visibility
        panels.forEach((panel) => {
          if (panel.getAttribute('data-panel') === targetId) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });
  });
</script>

<style>
  .tabs-container {
    width: 100%;
  }

  .tab-panels {
    margin-top: 1rem;
  }

  .tab-panel {
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
